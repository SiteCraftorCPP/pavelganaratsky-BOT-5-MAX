# Токен бота MAX: business.max.ru → Чат-боты → Интеграция → Получить токен
MAX_BOT_TOKEN=

# Несколько админов: user_id через запятую (пробелы после запятой допустимы)
ADMIN_IDS=111111111,222222222

# Базовый URL API (см. https://dev.max.ru/docs-api )
MAX_API_BASE=https://platform-api.max.ru

# При старте удалить webhook-подписки, чтобы работал Long Polling (GET /updates)
MAX_UNSUBSCRIBE_WEBHOOK_ON_START=1
